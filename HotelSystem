 }
 return true;
}
public double calculateTotalRevenue() {
return calculateTotalRevenue(0);}
//to insure the recursion works correctly we start at 0
private double calculateTotalRevenue(int num) {
    
    if (num >= numofreservations) {
        return 0.0;
    }
    double price = reservations[num].calculatePrice();
    return price + calculateTotalRevenue(num + 1);
}
